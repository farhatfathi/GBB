{
  "name": "gbb-portal",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "client:dev": "npm run dev -w client",
    "client:build": "npm run build -w client",
    "server:dev": "npm run dev -w server",
    "server:build": "npm run build -w server",
    "build": "npm run build -w client && npm run build -w server"
  }
}
